# =============================================================================
# SUPABASE AS DATABASE — what YOU must provide (only one secret string)
# =============================================================================
#
# I (the app) only need:  DATABASE_URL
#
# That is NOT the "Project URL" (https://xxx.supabase.co). That HTTPS URL is for
# Supabase Auth/JS clients — this project does not use it for the database.
#
# You get DATABASE_URL from Supabase like this:
#
#   1. https://supabase.com/dashboard → open your project (create one if needed).
#   2. Project Settings (gear) → Database.
#   3. Scroll to "Connection string" → tab "URI".
#   4. Copy the string. It starts with postgresql:// or postgres://
#   5. Replace [YOUR-PASSWORD] with your real database password
#      (same page: "Database password" — reset it if you forgot).
#
# For Render or other IPv4-only hosts: use the "Transaction pooler" URI if direct
# fails (port 6543, often includes ?pgbouncer=true). This app supports that.
#
# If your password contains @ # : / ? & % etc., URL-encode it, e.g. @ → %40
#   (Python:  from urllib.parse import quote_plus; quote_plus("your-password"))
#
# Put the final string in DATABASE_URL below, or in Render → Environment.
# Never commit .env or paste the full URI with password into chat.
#
# After deploy: open https://your-app/api/health — user_count should increase after
# first login bootstrap, or run:  python seed.py  in Shell for full demo data.
#
# =============================================================================

SECRET_KEY=

# Required when using Supabase (paste full URI on ONE line, no quotes unless needed)
DATABASE_URL=

# Optional — only if UI and API are on different domains
CORS_ORIGINS=

HTTP_PORT=8080
