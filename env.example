# Copy to .env (repo root or next to docker-compose) as needed.

SECRET_KEY=

# --- Supabase (PostgreSQL) — https://supabase.com/dashboard → your project → Settings → Database ---
#
# Use "Connection string" → URI. Two options:
#
# 1) Direct (port 5432, host db.xxxxx.supabase.co) — good for long-lived servers (Render Docker, local API).
#    Example:
#    DATABASE_URL=postgresql://postgres.[ref]:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
#
# 2) Transaction pooler (port 6543, often required for IPv4 / some hosts) — add ?pgbouncer=true to the URI
#    from the "Transaction" pooler tab. This app detects :6543 / pgbouncer=true and uses NullPool.
#
# Replace [YOUR-PASSWORD] with the database password from the same settings page.
# Do not commit real URLs or passwords.

DATABASE_URL=

# Optional local Docker: point backend at Supabase instead of SQLite
# DATABASE_URL=postgresql://postgres:...@db.xxx.supabase.co:5432/postgres

CORS_ORIGINS=
HTTP_PORT=8080

# --- Render ---
# render.yaml uses sync:false for DATABASE_URL — paste your Supabase URI when creating the Blueprint.
