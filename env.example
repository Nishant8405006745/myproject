# Copy to .env next to docker-compose.yml and adjust.

# Required for production (generate e.g. python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# Comma-separated browser origins allowed to call the API (needed if frontend and API use different hosts).
# Leave empty in Docker same-origin setup (browser only talks to nginx on HTTP_PORT).
# Example: https://app.example.com,https://www.example.com
CORS_ORIGINS=

# Published port for the web UI (default 8080 to avoid needing admin rights on port 80)
HTTP_PORT=8080

# --- Render (see render.yaml + Dockerfile at repo root) ---
# Blueprint deploys ONE web service: UI + /api on the same https://<name>.onrender.com URL.
# After deploy: Shell → python seed.py
